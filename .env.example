# ============================================================================
# RevOps Autopilot — Environment Variables Template
# 
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
# ============================================================================

# ─── Supabase ────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Clerk ───────────────────────────────────────────────────────────────────
# From: Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk URL configuration (defaults work for MVP)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
# From: Anthropic Console → API Keys
ANTHROPIC_KEY=

# ─── CRM Bi-Directional Sync (optional) ──────────────────────────────────────
# When set, /api/log-touch fires the touch payload to this URL after
# persisting locally. Wire it to a Zapier/Make/n8n webhook that creates
# a Salesforce Task (or HubSpot Activity, etc.). The handler must accept
# JSON and return 2xx for the touch to be marked synced.
#
# Example (Zapier "Catch Hook" trigger URL):
#   CRM_WEBHOOK_URL=
#
# Payload shape:
#   {
#     external_id, occurred_at, subject, body,
#     with_stakeholder: { id, name, email },
#     logged_by_email, opportunity_id, account_id,
#     source_system: "rep_log", type: "off_platform_touch"
#   }
#
# Leave blank to use rep_log only (touches stay in substrate locally,
# no CRM write — UI shows "rep log only" badge).
CRM_WEBHOOK_URL=

# ─── OpenAI Whisper (voice-touch transcription) ──────────────────────────────
# When set, the prep view's "🎤 Record" button transcribes voice memos via
# Whisper API. Reps speak a 30-second debrief; the system transcribes and
# pre-fills the touch composer for review/edit/save.
#
# From: https://platform.openai.com/api-keys
# Pricing: $0.006/minute (a 30-second touch = $0.0003)
# Model: whisper-1 (default, single model option)
#
# Without this key, the voice-record button is hidden — text input still
# works as before.
OPENAI_API_KEY=

# ─── Slack notifications (optional) ──────────────────────────────────────
# When set, methodology-escalation and verification-gap alerts post to
# Slack via incoming webhooks. Two channels supported:
#
#   SLACK_WEBHOOK_URL          — required for any Slack output. Receives
#                                "warn"-level verification gaps + any
#                                escalations when the manager URL is unset.
#   SLACK_MANAGER_WEBHOOK_URL  — optional. When set, "escalate_to_manager"
#                                alerts route here instead of the general
#                                channel. When unset, manager alerts fall
#                                back to SLACK_WEBHOOK_URL (never silently
#                                dropped).
#   SLACK_REP_USER_ID          — optional. Slack member ID (e.g. U07ABC123)
#                                of the rep responsible. When set, the rep
#                                gets @-mentioned on every alert so they
#                                receive a push notification (not just a
#                                channel-watcher silence).
#   SLACK_MANAGER_USER_ID      — optional. Slack member ID of the manager.
#                                Mentioned ONLY on escalate_to_manager
#                                alerts so the manager gets looped into
#                                the same thread as the rep. Leave unset
#                                to skip manager pings.
#
# How to find a Slack member ID:
#   In Slack → click profile picture → Profile → ⋮ More → Copy member ID
#   (looks like U07ABC123XY — starts with U)
#
# Webhook setup (5 minutes — channel posts):
#   1. https://api.slack.com/apps → Create New App → From scratch
#   2. Pick a name + workspace, hit Create
#   3. Sidebar → Incoming Webhooks → toggle Activate to On
#   4. Add New Webhook to Workspace → pick the channel → Allow
#   5. Copy the Webhook URL (starts with https://hooks.slack.com/services/)
#   6. Repeat for a manager-only channel if you want split routing
#
# Bot token setup (also 5 minutes — DMs to rep + manager):
#   When SLACK_BOT_TOKEN is set, alerts route to DMs (1:1 on warn,
#   group DM with rep + manager on escalations) — bypasses the channel
#   noise problem. Webhook config remains as fallback.
#
#   1. Same Slack app → sidebar → OAuth & Permissions
#   2. Scroll to Scopes → Bot Token Scopes → Add an OAuth Scope:
#        chat:write       (post messages)
#        im:write         (open 1:1 DMs)
#        mpim:write       (open multi-party DMs for rep + manager)
#   3. Scroll to top → Reinstall to <workspace> → Allow
#   4. Copy the Bot User OAuth Token (starts with xoxb-)
#
# Test:
#   npm run slack:test    # sends one warn + one escalation
SLACK_WEBHOOK_URL=
SLACK_MANAGER_WEBHOOK_URL=
SLACK_REP_USER_ID=
SLACK_MANAGER_USER_ID=
SLACK_BOT_TOKEN=

# ─── Slack interactivity (button clicks) ─────────────────────────────────
# When the alert message has buttons (Looks right / Looks wrong) and the
# rep clicks one, Slack POSTs to /api/slack/interact. We verify the
# request via HMAC against this signing secret.
#
#   1. Slack app → Basic Information → "App Credentials" section
#   2. Copy "Signing Secret"
#   3. Paste below
#
#   Then in Slack app → Interactivity & Shortcuts:
#   1. Toggle "Interactivity" to On
#   2. Request URL: https://<your-public-host>/api/slack/interact
#      For local dev, use ngrok (`ngrok http 3000`) and paste its URL.
SLACK_SIGNING_SECRET=

# ─── Gmail (drafts.create + voice-conditioning) ─────────────────────────────
# STATUS: Scaffolded May 11 2026. Adapter at lib/adapters/gmail.ts.
# Routes at app/api/gmail/*. Throws "not configured" until env is set.
#
# Setup:
#   1. https://console.cloud.google.com → create/select project
#   2. Enable Gmail API (APIs & Services → Library)
#   3. Credentials → OAuth client ID (Web application)
#      Authorized redirect URIs:
#        https://mallin.io/api/gmail/oauth-callback
#        https://<preview>.vercel.app/api/gmail/oauth-callback
#        http://localhost:3000/api/gmail/oauth-callback
#   4. OAuth consent screen → External → request scopes:
#        https://www.googleapis.com/auth/gmail.compose
#        https://www.googleapis.com/auth/gmail.modify
#      (For public production: app verification takes 1-6 weeks.
#       For design-partner unverified: capped at 100 users.)
#   5. Copy Client ID + Secret here:
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# ─── HubSpot (CRM read/write parity with Salesforce) ────────────────────────
# STATUS: Scaffolded May 11 2026. Adapter at lib/adapters/hubspot.ts.
# Routes at app/api/hs/*. Throws "not configured" until env is set.
#
# Setup:
#   1. https://developers.hubspot.com → sign up
#   2. Apps → Create app → name "Mallin"
#   3. Auth tab → set redirect URLs:
#        https://mallin.io/api/hs/oauth-callback
#        https://<preview>.vercel.app/api/hs/oauth-callback
#        http://localhost:3000/api/hs/oauth-callback
#   4. Scopes (Required):
#        crm.objects.deals.read / write
#        crm.objects.contacts.read / write
#        crm.objects.companies.read
#        crm.schemas.deals.read / write   (for custom MEDDPICC props)
#   5. Copy Client ID + Secret here:
HUBSPOT_OAUTH_CLIENT_ID=
HUBSPOT_OAUTH_CLIENT_SECRET=
HUBSPOT_OAUTH_REDIRECT_URI=

# ─── Resend (transactional email — pilot signup notifications) ─────────────
# STATUS: Live as of May 19 2026. Powers /api/pilot-signup → brendan@mallin.io.
# Without this set, signups still land in the pilot_signups table but no
# email notification is sent — see lib/email/resend.ts for the fallback.
#
# Setup:
#   1. https://resend.com → sign up (free tier: 100/day, 3000/month)
#   2. API Keys → Create API Key → name "mallin-prod-signups" → scope: send
#   3. Paste the key here:
RESEND_API_KEY=
#
#   4. (Optional but recommended) Domains → Add mallin.io → add the DNS
#      records Resend shows (SPF, DKIM, MX for return path). Once verified,
#      set RESEND_FROM_EMAIL to use your own domain. Until then leave it
#      unset — Resend falls back to onboarding@resend.dev which works
#      without domain verification.
#      Example after verification:
#        RESEND_FROM_EMAIL=
RESEND_FROM_EMAIL=
