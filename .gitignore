# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code internal state (worktrees, caches)
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright auth state (sign-in cookies — never commit)
scripts/decks/storageState.json
scripts/decks/storageState-*.json

# Playwright recording outputs (large binary files, regenerable)
docs/landing-concepts/assets/cockpit-full-tour/
docs/landing-concepts/assets/cockpit-tour/
docs/landing-concepts/assets/cockpit-tour-v2/
docs/landing-concepts/assets/mobile-check/
docs/landing-concepts/assets/cockpit-arcade-screens/*.png

# Outbound prospecting output — real contact info, never commit
.prospects/
# Scratch preview HTML served by .claude/launch.json (brief-preview)
.brief-preview/
# Ad-hoc migration scratch scripts
scripts/_tmp_*.mjs
