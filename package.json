{
  "name": "revops-autopilot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "verify-db": "tsx --env-file=.env.local scripts/verify-db-connection.ts",
    "db:status": "node --env-file=.env.local scripts/db/migrate.mjs status",
    "db:migrate": "node --env-file=.env.local scripts/db/migrate.mjs up",
    "db:baseline": "node --env-file=.env.local scripts/db/migrate.mjs baseline",
    "metrics": "tsx --env-file=.env.local scripts/metrics/usage.ts",
    "roi": "tsx --env-file=.env.local scripts/metrics/roi.ts",
    "pass15:test": "tsx --env-file=.env.local scripts/run-pass-1.5-manual.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "slack:test": "tsx --env-file=.env.local scripts/test-slack.ts",
    "pilots": "tsx --env-file=.env.local scripts/metrics/pilots.ts",
    "sdr:sim": "tsx --env-file=.env.local scripts/sdr-sim.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@clerk/elements": "^0.24.16",
    "@clerk/nextjs": "^6.39.3",
    "@supabase/supabase-js": "^2.104.1",
    "@vercel/analytics": "^1.4.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "gray-matter": "^4.0.3",
    "jsforce": "^3.10.14",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "next": "15.5.15",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.1.4",
    "react-dom": "^19.1.4",
    "simple-icons": "^16.19.0",
    "stripe": "^17.7.0",
    "unpdf": "^1.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
